{% load static %}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Add Brand | EchoPods Admin</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    body {
      background: radial-gradient(circle at top right, #0f172a, #020617);
      color: #e2e8f0;
      font-family: 'Poppins', sans-serif;
      overflow-x: hidden;
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 100vh;
    }

    /* ===== NAVBAR ===== */
        .navbar {
      background: rgba(15, 23, 42, 0.85);
      backdrop-filter: blur(12px);
      box-shadow: 0 4px 20px rgba(56,189,248,0.15);
    }
    .navbar-brand {
      color: #38bdf8 !important;
      font-weight: 700;
      font-size: 1.8rem;
      letter-spacing: 1.5px;
    }
    .nav-link {
      color: #f8fafc !important;
      border: 1px solid transparent;
      border-radius: 25px;
      padding: 6px 16px;
      transition: 0.3s;
    }
    .nav-link:hover {
      border-color: #38bdf8;
      background: rgba(56,189,248,0.15);
      transform: translateY(-2px);
    }
    .navbar-toggler {
      border: none;
    }
    .navbar-toggler-icon {
      filter: invert(80%);
    }

    .brand-card {
      background: rgba(30, 41, 59, 0.85);
      border: 1px solid rgba(56, 189, 248, 0.4);
      border-radius: 20px;
      padding: 40px;
      width: 100%;
      max-width: 420px;
      text-align: center;
      box-shadow: 0 0 40px rgba(56,189,248,0.2);
      backdrop-filter: blur(10px);
      animation: fadeIn 0.8s ease;
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: scale(0.95); }
      to { opacity: 1; transform: scale(1); }
    }

    h3 {
      color: #38bdf8;
      font-weight: 700;
      margin-bottom: 1.5rem;
    }

    .form-control {
      background: rgba(241, 245, 249, 0.95);
      border: 1px solid rgba(56,189,248,0.4);
      border-radius: 10px;
      padding: 10px;
      color: #0f172a;
    }

    .btn-main {
      background: linear-gradient(90deg, #06b6d4, #3b82f6);
      border: none;
      padding: 12px 36px;
      color: white;
      font-weight: 600;
      border-radius: 50px;
      transition: 0.3s;
      width: 100%;
    }
    .btn-main:hover {
      transform: scale(1.05);
      box-shadow: 0 0 20px rgba(56,189,248,0.4);
    }

    a.back-btn {
      color: #38bdf8;
      text-decoration: none;
      display: block;
      margin-top: 20px;
    }
  </style>
</head>
<body>
  <!-- ===== NAVBAR ===== -->
  <nav class="navbar navbar-expand-lg fixed-top">
    <div class="container-fluid">
      <a class="navbar-brand" href="#">EchoPods Admin</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse justify-content-end" id="navbarNav">
        <ul class="navbar-nav gap-3 align-items-center">
          <li class="nav-item"><a class="nav-link" href="{% url 'admin_home' %}">Dashboard</a></li>
          <li class="nav-item"><a class="nav-link" href="{% url 'view_users' %}">Users</a></li>
          <li class="nav-item"><a class="nav-link" href="{% url 'add_brand' %}">Brands</a></li>
          <li class="nav-item"><a class="nav-link" href="{% url 'add_product' %}">Products</a></li>
          <li class="nav-item"><a class="nav-link text-danger" href="{% url 'logout_fun' %}">Logout</a></li>
        </ul>
      </div>
    </div>
  </nav>



</body>
</html>
